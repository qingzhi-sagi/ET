<Project Sdk="Microsoft.NET.Sdk">    
    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework> 
        <RootNamespace>ET</RootNamespace>
        <LangVersion>default</LangVersion>
        <AssemblyName>ET.Hotfix</AssemblyName>
        <Configurations>Debug;Release</Configurations>
        <Platforms>AnyCPU</Platforms>
    </PropertyGroup>
    <PropertyGroup>
        <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
        <SatelliteResourceLanguages>en</SatelliteResourceLanguages>
    </PropertyGroup>
    <PropertyGroup>
        <ETRootDir>$([MSBuild]::EnsureTrailingSlash($([System.IO.Path]::GetFullPath('$(MSBuildThisFileDirectory)..\..\..\..\' ))))</ETRootDir>
        <ETRootDirForPwsh>$(ETRootDir).</ETRootDirForPwsh>
        <MainPackageFile>$(ETRootDir)MainPackage.txt</MainPackageFile>
        <MainPackageDesignTimeProps>$(MSBuildProjectDirectory)/$(BaseIntermediateOutputPath)ET.Hotfix.MainPackage.g.props</MainPackageDesignTimeProps>
    </PropertyGroup>
    
    <Import Project="$(MainPackageDesignTimeProps)" Condition="'$(DesignTimeBuild)' == 'true' and Exists('$(MainPackageDesignTimeProps)')" />
    
    <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Debug|AnyCPU'">
        <DefineConstants>DOTNET;ET10</DefineConstants>
        <OutputPath>$(ETRootDir)Bin</OutputPath> 
        <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
        <NoWarn></NoWarn>
        <Optimize>false</Optimize>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release|AnyCPU'">
        <DefineConstants>DOTNET;ET10</DefineConstants>
        <OutputPath>$(ETRootDir)Bin</OutputPath>
        <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
        <AllowUnsafeBlocks>false</AllowUnsafeBlocks>
        <NoWarn></NoWarn>
        <Optimize>true</Optimize>
        <DebugType>full</DebugType>
        <DebugSymbols>true</DebugSymbols>
        <Deterministic>false</Deterministic>
    </PropertyGroup>
    
    <Target Name="GenerateDesignTimePackageProps" BeforeTargets="BeforeBuild" Inputs="$(MainPackageFile)" Outputs="$(MainPackageDesignTimeProps)" Condition="Exists('$(MainPackageFile)')">
        <Exec Command="pwsh -NoProfile -ExecutionPolicy Bypass -File &quot;$(MSBuildThisFileDirectory)Generate-ETHotfixMainPackageProps.ps1&quot; -RootDir &quot;$(ETRootDirForPwsh)&quot; -OutputPath &quot;$(MainPackageDesignTimeProps)&quot;" />
    </Target>
    
    <Target Name="AddPackageCompileItems" BeforeTargets="BeforeBuild;BeforeResolveReferences;CoreCompile">
        <ReadLinesFromFile File="$(MainPackageFile)">
            <Output TaskParameter="Lines" ItemName="PackageNames" />
        </ReadLinesFromFile>
        <ItemGroup>
            <PackageNames Remove="@(PackageNames)" Condition="'%(Identity)' == ''" />
        </ItemGroup>
        <ItemGroup>
            <HotfixShareGlobs Include="@(PackageNames->'$(ETRootDir)Packages/%(Identity)/Scripts/Hotfix/Share/**/*.cs')" />
            <HotfixServerGlobs Include="@(PackageNames->'$(ETRootDir)Packages/%(Identity)/Scripts/Hotfix/Server/**/*.cs')" />
            <HotfixClientGlobs Include="@(PackageNames->'$(ETRootDir)Packages/%(Identity)/Scripts/Hotfix/Client/**/*.cs')" />
            <CodeModeHotfixGlobs Include="@(PackageNames->'$(ETRootDir)Packages/%(Identity)/CodeMode/Hotfix/Server/**/*.cs')" />
        </ItemGroup>
        <CreateItem Include="@(HotfixShareGlobs)">
            <Output TaskParameter="Include" ItemName="Compile" />
        </CreateItem>
        <CreateItem Include="@(HotfixServerGlobs)">
            <Output TaskParameter="Include" ItemName="Compile" />
        </CreateItem>
        <CreateItem Include="@(HotfixClientGlobs)">
            <Output TaskParameter="Include" ItemName="Compile" />
        </CreateItem>
        <CreateItem Include="@(CodeModeHotfixGlobs)">
            <Output TaskParameter="Include" ItemName="Compile" />
        </CreateItem>
    </Target>

    <Target Name="AddTestCompileItems" BeforeTargets="BeforeBuild;BeforeResolveReferences;CoreCompile" Condition="'$(Configuration)'=='Debug'">
        <ReadLinesFromFile File="$(MainPackageFile)">
            <Output TaskParameter="Lines" ItemName="TestPackageNames" />
        </ReadLinesFromFile>
        <ItemGroup>
            <TestPackageNames Remove="@(TestPackageNames)" Condition="'%(Identity)' == ''" />
            <HotfixTestGlobs Include="@(TestPackageNames->'$(ETRootDir)Packages/%(Identity)/Scripts/Hotfix/Test/**/*.cs')" />
        </ItemGroup>
        <CreateItem Include="@(HotfixTestGlobs)">
            <Output TaskParameter="Include" ItemName="Compile" />
        </CreateItem>
    </Target>
    
    <ItemGroup>
        <ProjectReference Include="$(ETRootDir)Packages/cn.etetet.memorypack/DotNet~/ET.MemoryPack.Generator/ET.MemoryPack.Generator.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="false" />
        <ProjectReference Include="$(ETRootDir)Packages/cn.etetet.sourcegenerator/DotNet~/ET.SourceGenerator/ET.SourceGenerator.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="false" />
        <ProjectReference Include="..\Model\ET.Model.csproj" />
    </ItemGroup>
    
    <ItemGroup>
        <CompilerVisibleProperty Include="DotNetAssembly" />
    </ItemGroup>
    
    <ItemGroup>
      <Folder Include="..\..\..\cn.etetet.test\Scripts\Hotfix\Share\">
        <Link>Packages\cn.etetet.test\Scripts\Hotfix\Share</Link>
      </Folder>
    </ItemGroup>
</Project>
